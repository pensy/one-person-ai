# 运行环境:development / production
APP_ENV=development

# 数据库配置(Docker 部署时由 docker-compose 传入)
DATABASE_URL=mysql+pymysql://ai_user:ai_pass@mysql:3306/ai_tools_db?charset=utf8mb4

# JWT 配置 —— 生产环境(APP_ENV=production)必须改为随机长字符串
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# CORS 白名单(逗号分隔);仅开发用 * 全开
CORS_ORIGINS=http://localhost:3000

# Worker 服务地址(gRPC)
WORKER_ADDR=localhost:50051

# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# GitHub App(Phase 2 启用前留空)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
